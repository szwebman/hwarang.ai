generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

generator pyclient {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// 사용자
// ============================================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  hashedPassword String?
  image          String?
  role           UserRole @default(USER)

  // 소셜 로그인 (NextAuth)
  accounts Account[]
  sessions Session[]

  // 관계
  plan          Plan?          @relation(fields: [planId], references: [id])
  planId        String?
  tokenBalance  TokenBalance?
  apiKeys       ApiKey[]
  conversations Conversation[]
  usageRecords  UsageRecord[]
  payments      Payment[]
  rlhfFeedback  RLHFFeedback[]

  // 상태
  isActive      Boolean   @default(true)
  emailVerified DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([planId])
}

// ============================================================
// NextAuth 소셜 로그인 (Google, Kakao)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

// ============================================================
// 플랜 (구독 상품) - 토큰 패키지만 차이남, 모든 모델 사용 가능
// ============================================================

model Plan {
  id          String  @id @default(cuid())
  name        String  @unique // "free", "starter", "pro", "business", "enterprise"
  displayName String // "Free", "Starter", "Pro", "Business", "Enterprise"
  description String?

  // 가격
  priceMonthly Int @default(0) // 월 가격 (원)
  priceYearly  Int @default(0) // 연 가격 (원)

  // ⭐ 토큰 기반 제한 (모든 모델 공통 토큰 풀)
  tokensIncluded  Int @default(50000000) // 플랜에 포함된 월 토큰 수 (5배 상향)
  dailyTokenLimit Int @default(5000000) // 하루 최대 소진 토큰 (폭주 방지, 5배 상향)
  maxTokensPerReq Int @default(16384) // 요청 1회당 최대 토큰
  concurrentReqs  Int @default(1) // 동시 요청 수
  apiKeysAllowed  Int @default(1) // API 키 개수

  // 초과 토큰 구매 가능 여부
  allowOverage    Boolean @default(false) // 토큰 소진 후 추가 구매 가능?
  overagePrice7b  Int     @default(0) // 초과 토큰 가격 (7B 모델, 원/1K토큰)
  overagePrice30b Int     @default(0) // 초과 토큰 가격 (30B 모델, 원/1K토큰)

  // 사용 가능 모델
  models String[] // ["hwarang-7b", "hwarang-30b"]

  // 기능 접근 (플랜으로 제한)
  features     String[] // ["chat", "api", "code", "legal", "tax", "priority_queue"]
  supportLevel String   @default("community") // "community", "email", "priority", "dedicated"

  // 상태
  isActive Boolean @default(true)
  isPublic Boolean @default(true)

  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// AI 모델 및 토큰 단가 (관리자 제어 가능)
// ============================================================

model AIModel {
  id          String  @id @default(cuid())
  name        String  @unique // "hwarang-v3", "hwarang-coder", "hwarang-general"
  displayName String // "Hwarang V3 (최강)", "Hwarang Coder", "Hwarang General"
  description String?

  // 실제 모델 연결
  backendId String // vLLM 모델 ID (베이스 모델 — 항상 채워짐)
  loraName  String? // vLLM 의 LoRA 이름 (있으면 LoRA 라우팅, 없으면 베이스만)
  endpoint  String  @default("http://localhost:8000")

  // ⭐ 토큰 단가 (화랑 토큰 소비 배수)
  inputMultiplier  Float @default(0.1) // 입력 토큰 배수
  outputMultiplier Float @default(0.3) // 출력 토큰 배수 (보통 입력보다 비쌈)

  // 컨텍스트 & 제약
  maxContextLength Int @default(32768)
  maxOutputTokens  Int @default(16384) // 긴 코드 작성 시 잘림 방지 (이전 4096 → 16384)

  // 카테고리 & 태그 (도메인 라우팅 키)
  category String   @default("general") // "general", "coding", "legal", "tax", "medical", "reasoning"
  tier     String   @default("standard") // "basic", "standard", "premium", "flagship"
  tags     String[]

  // 도메인 기본 라우트 표시 — 같은 category 안에서 isDomainDefault 가 true 인 게 우선 사용됨
  isDomainDefault Boolean @default(false)

  // 접근 제어
  minPlan   String? // 최소 플랜 이름 (null이면 전체)
  isPublic  Boolean @default(true)
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  // 서빙 상태
  status      String    @default("ready")
  lastCheckAt DateTime?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, tier])
  @@index([isActive, isPublic])
}

// ============================================================
// 사용자 토큰 잔액 (충전/차감 방식)
// ============================================================

model TokenBalance {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 잔액
  balance      Int @default(0) // 현재 남은 토큰 수
  totalUsed    Int @default(0) // 누적 사용 토큰
  totalCharged Int @default(0) // 누적 충전 토큰

  // ⭐ 하루 소진 관리
  dailyUsed    Int       @default(0) // 오늘 사용한 토큰
  dailyLimit   Int       @default(5000000) // 오늘 최대 소진 가능 (플랜에서 가져옴, 5배 상향)
  dailyResetAt DateTime? // 오늘 리셋 시간 (자정)

  // 월간 리셋 (구독 플랜용)
  monthlyReset   Boolean   @default(true) // 매월 토큰 리셋 여부
  monthlyUsed    Int       @default(0) // 이번 달 사용한 토큰
  monthlyResetAt DateTime? // 다음 월 리셋 시간 (다음 달 1일)
  lastResetAt    DateTime? // 마지막 리셋 시간
  nextResetAt    DateTime? // 다음 리셋 시간

  updatedAt DateTime @updatedAt
}

// ============================================================
// 토큰 거래 내역 (충전/사용/환불 추적)
// ============================================================

model TokenTransaction {
  id          String               @id @default(cuid())
  userId      String
  type        TokenTransactionType
  amount      Int // 토큰 수 (양수: 충전, 음수: 사용)
  balance     Int // 거래 후 잔액
  description String // "월간 플랜 충전", "API 호출 (30B)", "토큰 구매"
  metadata    Json? // 추가 정보 (모델명, 요청ID 등)
  createdAt   DateTime             @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

enum TokenTransactionType {
  PLAN_CREDIT // 플랜 구독으로 토큰 충전 (매월)
  PURCHASE // 토큰 직접 구매
  USAGE // API 호출로 토큰 사용
  REFUND // 환불
  BONUS // 프로모션/이벤트 보너스
  ADMIN_ADJUST // 관리자 수동 조정
  GRID_REWARD // ⭐ GPU 기여 보상 (Hwarang Grid)
  GRID_STREAK // Grid 연속 참여 보너스
  REFERRAL // 친구 초대 보상
}

// ============================================================
// API 키
// ============================================================

model ApiKey {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String // "Production", "Development" 등
  keyHash   String @unique // SHA-256 해시 (실제 키는 저장 안 함)
  keyPrefix String // "hk-a1b2c3..." (앞 8자, 식별용)

  // 권한
  permissions String[] @default(["chat"]) // ["chat", "api", "code", "legal", "tax"]
  rateLimit   Int      @default(60) // 분당 요청 수

  // 상태
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?

  // 사용 기록
  usageRecords UsageRecord[]

  // 다중 기기 지원 (Hwarang Grid 데스크탑 에이전트 / VS Code 등)
  // nullable — 기존 ApiKey 호환 (디바이스 메타가 없는 키도 그대로 유효)
  deviceName        String? // 사용자 지정 또는 hostname (예: "Jin's MacBook Pro")
  deviceOs          String? // "darwin" / "windows" / "linux"
  deviceArch        String? // "x86_64" / "aarch64"
  deviceGpu         String? // "RTX 5090" / "Apple M2 Max" / "RTX 3090"
  deviceFingerprint String? // hostname + MAC 조합 SHA256 (선택)
  deviceKind        String? // "agent_grid" / "vscode" / "cli" — 분류용
  lastSeenAt        DateTime? // 하트비트 갱신 시각

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([keyHash])
  @@index([userId, deviceKind])
  @@index([deviceFingerprint])
}

// ============================================================
// 사용량 기록
// ============================================================

model UsageRecord {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyId String?
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id])

  // 요청 정보
  model            String // "hwarang-code-7b", "hwarang-code-30b"
  endpoint         String // "/v1/chat/completions"
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  chargedTokens    Int    @default(0) // 과금 토큰 (모델별 배수 적용)
  inputMultiplier  Float  @default(1.0) // 입력 토큰 배수
  outputMultiplier Float  @default(1.0) // 출력 토큰 배수
  latencyMs        Int
  statusCode       Int    @default(200)

  // 도메인
  domain String? // "code", "legal", "tax"

  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([apiKeyId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ============================================================
// 결제
// ============================================================

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 결제 정보
  amount   Int // 결제 금액 (원)
  currency String        @default("KRW")
  status   PaymentStatus @default(PENDING)
  method   String? // "card", "transfer", "kakao"

  // PG사 연동
  pgProvider  String? // "tosspayments", "kakaopay"
  pgOrderId   String? @unique // PG사 주문번호
  pgPaymentId String? // PG사 결제번호

  // 상품 정보
  planId      String? // 어떤 플랜 결제인지
  planName    String?
  billingType String  @default("monthly") // "monthly", "yearly", "one-time"

  // 기간
  periodStart DateTime? // 구독 시작일
  periodEnd   DateTime? // 구독 종료일

  description String?

  paidAt     DateTime?
  canceledAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([pgOrderId])
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELED
  REFUNDED
  FAILED
}

// ============================================================
// 대화 (기존)
// ============================================================

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("New Chat")
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  model     String    @default("hwarang-code-7b")
  domain    String? // "code", "legal", "tax"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
}

model Message {
  id             String       @id @default(cuid())
  role           String // "user" | "assistant" | "system" | "tool"
  content        String       @db.Text
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tokenCount     Int?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ============================================================
// 시스템 설정 (관리자용)
// ============================================================

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique // "maintenance_mode", "max_concurrent_users" 등
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ============================================================
// Living Knowledge Mesh (HLKM)
// Temporal Causal Knowledge Mesh - 시간/인과/모순 인식 지식 그래프
// ============================================================

model KnowledgeFact {
  id           String  @id @default(cuid())
  content      String  @db.Text
  contentHash  String // 중복 감지용 sha256
  embeddingHex String? @db.Text // pgvector 확장 연결 전 임시 (hex encoded float32[])

  // 분류
  domain   String // "law", "tech", "medical", "finance", "general"
  entity   String? // 같은 주제(최저시급, 근로기준법) 묶는 키
  tags     String[] @default([])
  language String   @default("ko")

  // 시간 축 (Temporal)
  validFrom      DateTime
  validTo        DateTime? // NULL = 현재 유효
  createdAt      DateTime  @default(now())
  lastVerifiedAt DateTime  @default(now())
  nextCheckAt    DateTime? // 반감기 기반 자동 재검증 시점

  // 신뢰도 (Dynamic Confidence)
  confidenceT0 Float @default(1.0) // 초기 신뢰도
  halfLifeDays Int? // 카테고리별 반감기 (NULL = 영속)

  // 상태 (Predictive)
  status               KnowledgeStatus @default(CONFIRMED)
  predictedValidFrom   DateTime? // pending일 때 예상 발효일
  predictionConfidence Float? // 예측 확률 (0~1)
  expiredReason        String?

  // 출처
  source     String // 출처 이름
  sourceUrl  String?
  sourceType String  @default("user") // user, crawl, official, agent, community

  // 계층 (Multi-tier privacy)
  visibility  KnowledgeVisibility @default(PUBLIC)
  ownerUserId String? // private일 때만

  // 버전/승계 관계
  supersedesId String?
  supersedes   KnowledgeFact?  @relation("FactVersionChain", fields: [supersedesId], references: [id])
  supersededBy KnowledgeFact[] @relation("FactVersionChain")

  // 관계 (그래프 엣지)
  outgoingEdges KnowledgeEdge[] @relation("FromFact")
  incomingEdges KnowledgeEdge[] @relation("ToFact")

  // 기여 / 보상
  contributedBy String? // userId
  rewardPaid    Int     @default(0) // 지급된 토큰 (HWARANG 코인)

  // ═══ TAL (Truth Arbitration Layer) v3 ═══
  sourceTier      SourceTier? // primary_official/peer_reviewed/general/user_generated
  sourceAuthority Float           @default(0.5) // 도메인별 출처 위계 권위 (0~1)
  originalFactId  String? // 복사본이면 원본 id
  originalFact    KnowledgeFact?  @relation("FactProvenance", fields: [originalFactId], references: [id])
  copies          KnowledgeFact[] @relation("FactProvenance")
  provenanceType  ProvenanceType  @default(INDEPENDENT)
  copySimilarity  Float? // 복사본일 때 원본과의 유사도

  stance           FactStance @default(FACTUAL)
  stanceConfidence Float      @default(1.0)

  falsifiability Falsifiability @default(FALSIFIABLE)

  retracted        Boolean   @default(false)
  retractedAt      DateTime?
  retractionReason String?   @db.Text
  retractionSource String? // 정정 출처

  parentClaimId String? // claim decomposition 부모
  parentClaim   KnowledgeFact?  @relation("ClaimDecomp", fields: [parentClaimId], references: [id])
  subClaims     KnowledgeFact[] @relation("ClaimDecomp")
  isAtomic      Boolean         @default(true) // 원자적 주장인지

  arbitratedScore Float? // 최종 arbitrated_confidence 캐시

  // ═══ v3.1: Multi-modal, Bias, Cross-lingual ═══
  mediaType     MediaType @default(TEXT)
  mediaUrl      String? // 이미지/영상 URL
  mediaHash     String? // perceptual hash (pHash/dHash)
  mediaMetadata Json? // duration, resolution, size, exif 등

  languageOriginal     String? // "ko", "en", "ja" 원본 언어
  translatedFromFactId String? // 번역 원본 fact id
  translatedFrom       KnowledgeFact?  @relation("Translation", fields: [translatedFromFactId], references: [id])
  translations         KnowledgeFact[] @relation("Translation")
  translationQuality   Float? // 번역 품질 추정 0~1

  biasScore      Float? // 정치 편향 -1 (진보) ~ 0 (중립) ~ +1 (보수)
  biasLabel      BiasLabel?
  biasDetections BiasDetection[]

  // v3.2: Uncertainty quantification
  confidenceInterval    Json? // {"lower": 0.78, "upper": 0.92, "method": "bootstrap"}
  uncertaintyMethod     String? // 'bayesian', 'bootstrap', 'monte_carlo', 'ensemble'
  credibleIntervalWidth Float? // upper - lower, 작을수록 확실
  mediaFact             MediaFact? @relation("KnowledgeFactMedia")

  // v3.3: 코드 도메인 품질 평가 (research/quality/code_quality_filter.py)
  qualityScore   Float? // 0~1, 6 요소 가중 합 (source/length/code/syntax/...)
  qualityFactors Json? // {"source_trust":0.8,"syntax":1.0,...}
  isHighQuality  Boolean @default(false) // qualityScore >= 0.7

  @@index([domain, validTo])
  @@index([entity, validFrom])
  @@index([status, nextCheckAt])
  @@index([contentHash])
  @@index([ownerUserId, visibility])
  @@index([sourceTier, domain])
  @@index([retracted])
  @@index([originalFactId])
  @@index([parentClaimId])
  @@index([mediaType])
  @@index([languageOriginal])
  @@index([translatedFromFactId])
  @@index([biasLabel])
}

enum SourceTier {
  PRIMARY_OFFICIAL // 법령 원문, 정부 공식 고시
  PEER_REVIEWED // 논문, 학술지
  SPECIALIZED_MEDIA // 법률신문, 의학신문 같은 전문 매체
  GENERAL_MEDIA // 종합 신문/방송
  USER_GENERATED // 블로그, 커뮤니티, SNS
  UNKNOWN
}

enum ProvenanceType {
  INDEPENDENT // 독립 보도
  COPY_OF // 같은 내용 복사/전재
  TRANSLATION // 번역본
  QUOTATION // 인용 (일부 발췌)
  SUMMARY // 요약본
  DERIVED // 파생 (해석/분석)
}

enum FactStance {
  FACTUAL // 검증 가능한 사실 (수치, 날짜, 법령)
  INTERPRETATION // 해석 (전문가의 법률 해석)
  OPINION // 의견 (좋다/나쁘다)
  CONTESTED // 논쟁 중 (양측 입장 존재)
  PROPAGANDA // 선전/홍보성
}

enum Falsifiability {
  UNFALSIFIABLE // 수학 정리, 논리적 진리 (반증 불가)
  FALSIFIABLE // 관측 가능한 사실 (반증 가능)
  TIME_DEPENDENT // 미래 예측 (시간이 지나면 확인됨)
  VALUE_JUDGMENT // 가치 판단 (반증 개념이 안 맞음)
  UNCLEAR // 분류 불명확
}

enum MediaType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT // PDF, DOCX 등
  MIXED // 텍스트 + 이미지 혼합
}

enum BiasLabel {
  FAR_LEFT // -1.0 ~ -0.66
  PROGRESSIVE // -0.66 ~ -0.2
  CENTRIST // -0.2 ~ +0.2
  CONSERVATIVE // +0.2 ~ +0.66
  FAR_RIGHT // +0.66 ~ +1.0
  MIXED // 양측 요소 섞임 (인용 위주)
  NON_POLITICAL // 정치 도메인 아님
  UNKNOWN
}

enum KnowledgeStatus {
  CONFIRMED // 확정된 사실
  PENDING // 미확정 (예: 법안 발의만 된 상태)
  PREDICTED // AI가 예측한 미래 상태
  EXPIRED // 만료됨 (과거)
  RETRACTED // 철회/무효 (출처 자체 취소)
  DISPUTED // 모순 발생 중 (관리자 검토 대기)
}

enum KnowledgeVisibility {
  PUBLIC // 모든 사용자 공유
  PRIVATE // 개인 전용 (암호화)
  TEAM // 팀/워크스페이스 공유
  RESTRICTED // 특정 권한 있어야 접근
}

model KnowledgeEdge {
  id         String        @id @default(cuid())
  fromFactId String
  fromFact   KnowledgeFact @relation("FromFact", fields: [fromFactId], references: [id], onDelete: Cascade)
  toFactId   String
  toFact     KnowledgeFact @relation("ToFact", fields: [toFactId], references: [id], onDelete: Cascade)

  relationType KnowledgeRelation
  strength     Float             @default(1.0) // 0.0~1.0
  evidence     String?           @db.Text // 판단 근거 텍스트
  verifiedBy   String            @default("ai") // ai, human, consensus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromFactId, toFactId, relationType])
  @@index([relationType, strength])
}

enum KnowledgeRelation {
  CAUSES // A → B 야기
  ENABLES // A → B 가능케 함
  CONTRADICTS // A ⚡ B 모순
  SUPPORTS // A → B 보강/증거
  DERIVED_FROM // A ← B 파생
  RELATED_TO // A ~ B 관련
  SPECIALIZES // A ⊂ B 특수화
  GENERALIZES // A ⊃ B 일반화
  TEMPORAL_AFTER // A > B 시간 후속
  ALTERNATIVE_TO // A ≈ B 대안
}

// 자가 검증 / 재확인 로그
model KnowledgeVerification {
  id              String   @id @default(cuid())
  factId          String
  verifiedAt      DateTime @default(now())
  method          String // 'source_refetch', 'llm_check', 'cross_source', 'community'
  result          String // 'unchanged', 'updated', 'invalidated', 'source_gone'
  confidenceDelta Float    @default(0.0)
  notes           String?  @db.Text

  @@index([factId, verifiedAt])
}

// 모순 사건 기록
model KnowledgeConflict {
  id              String    @id @default(cuid())
  factAId         String
  factBId         String
  detectedAt      DateTime  @default(now())
  resolutionState String    @default("open") // open, resolved_A, resolved_B, coexist, escalated
  resolutionNote  String?   @db.Text
  resolvedBy      String? // userId of admin
  resolvedAt      DateTime?

  @@index([resolutionState, detectedAt])
}

// 지식 기여 이력 (코인 지급 근거)
model KnowledgeContribution {
  id              String   @id @default(cuid())
  factId          String
  contributorId   String
  acceptedAt      DateTime @default(now())
  qualityScore    Float // 0~1
  uniquenessScore Float
  reward          Int // 지급 토큰
  votesUp         Int      @default(0)
  votesDown       Int      @default(0)

  @@index([contributorId, acceptedAt])
}

// 지식 공백 (사용자가 자주 묻지만 답 못한 주제)
model KnowledgeGap {
  id             String    @id @default(cuid())
  topic          String
  failureCount   Int       @default(1)
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  status         String    @default("open") // open, searching, proposed, filled, abandoned
  filledByFactId String?
  searchAttempts Int       @default(0)
  lastSearchAt   DateTime?

  @@unique([topic])
  @@index([status, failureCount])
}

// ============================================================
// HLKM v2 개량: XAI / Reputation / Community / Hypothesis / Audit / GDPR
// ============================================================

// 출처 신뢰도 (④ Source Reputation)
model SourceReputation {
  id                 String   @id @default(cuid())
  source             String   @unique
  sourceType         String   @default("user") // user/crawl/official/agent/community
  totalFacts         Int      @default(0)
  confirmedUnchanged Int      @default(0) // 재검증 때 OK
  invalidated        Int      @default(0) // 나중에 틀린 것으로 판명
  updatedCount       Int      @default(0) // 자가 검증 시 내용 변경됨
  reputation         Float    @default(0.7) // 0~1 (초기 0.7 중립)
  lastUpdated        DateTime @default(now())
  notes              String?  @db.Text

  @@index([reputation])
}

// 지식 커뮤니티 (② Community Detection)
model KnowledgeCommunity {
  id            String   @id @default(cuid())
  name          String // 자동 또는 수동 명명
  algorithm     String   @default("louvain")
  domain        String?
  factIds       String[] // 구성원 fact ids
  summary       String?  @db.Text // LLM 생성 요약
  summaryModel  String? // 요약 생성 모델 버전
  size          Int      @default(0)
  cohesion      Float    @default(0.0) // 내부 유사도
  centralFactId String? // 대표 사실
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  version       Int      @default(1)

  @@index([domain, size])
  @@index([centralFactId])
}

// 자동 생성된 가설 (⑦ Hypothesis Generation)
model KnowledgeHypothesis {
  id          String            @id @default(cuid())
  statement   String            @db.Text // "A가 C를 가능하게 한다" 같은 가설 문장
  relation    KnowledgeRelation
  fromFactId  String
  toFactId    String
  pathFactIds String[] // 추론 경로의 중간 사실들
  confidence  Float // 0~1
  rationale   String            @db.Text // LLM 생성 근거
  status      String            @default("pending") // pending, accepted, rejected
  reviewedBy  String? // userId
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime          @default(now())

  @@index([status, confidence])
}

// 답변 근거 체인 (① XAI)
model AnswerEvidence {
  id                String    @id @default(cuid())
  questionHash      String // 질문 해시 (재사용)
  questionText      String    @db.Text
  answerText        String    @db.Text
  factIds           String[] // 근거로 쓴 사실들
  confidenceFactors Json // {source_reputation, time_decay, cross_source}
  asOfDate          DateTime?
  userId            String?
  createdAt         DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([questionHash])
}

// 블록체인 앵커링 (⑨ Audit Log)
model AuditAnchor {
  id           String       @id @default(cuid())
  anchorDate   DateTime // 하루치 묶음 날짜 (자정 기준)
  merkleRoot   String // 머클 루트 해시
  eventCount   Int // 이 날짜의 이벤트 개수
  chainTxHash  String? // HWARANG 체인 트랜잭션 해시 (anchored 후)
  chainBlockId String?
  anchoredAt   DateTime?
  events       AuditEvent[]

  @@unique([anchorDate])
  @@index([anchoredAt])
}

model AuditEvent {
  id         String       @id @default(cuid())
  anchorId   String?
  anchor     AuditAnchor? @relation(fields: [anchorId], references: [id])
  eventType  String // fact.create, fact.update, fact.delete, community.update, ...
  targetId   String // 대상 엔티티 ID
  actorId    String? // userId 또는 system
  beforeHash String? // 변경 전 상태 해시
  afterHash  String // 변경 후 상태 해시
  metadata   Json?
  occurredAt DateTime     @default(now())

  @@index([eventType, occurredAt])
  @@index([targetId])
  @@index([anchorId])
}

// ═══ TAL (Truth Arbitration Layer) v3 신규 테이블 ═══

// 도메인별 출처 위계 레지스트리 (① Source Hierarchy)
model SourceHierarchyRule {
  id        String     @id @default(cuid())
  domain    String // law, medical, politics, general, ...
  level     Int // 1이 최상위
  pattern   String // 정규식 또는 URL 도메인 매칭
  tier      SourceTier
  authority Float // 0~1
  country   String     @default("KR") // v3.2: KR, US, JP, EU, CN, GLOBAL
  note      String?    @db.Text
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([domain, level])
  @@index([tier])
  @@index([country, domain])
}

// 정정/철회 사건 (③ Retraction Tracking)
model RetractionEvent {
  id             String    @id @default(cuid())
  factId         String // 영향받은 사실
  retractedBy    String // 정정 발행 출처
  retractionUrl  String?
  retractionDate DateTime
  retractionType String // correction/retraction/update
  reason         String    @db.Text
  detectedAt     DateTime  @default(now())
  detectedBy     String    @default("auto") // auto/manual/external
  verified       Boolean   @default(false)
  verifiedBy     String? // userId
  verifiedAt     DateTime?

  @@index([factId])
  @@index([retractionDate])
  @@index([verified])
}

// 전파 관계 (② Provenance Chain)
model ProvenanceEdge {
  id           String         @id @default(cuid())
  sourceFactId String // 복사한 쪽
  targetFactId String // 원본
  relationType ProvenanceType
  similarity   Float // Jaccard 또는 embedding 유사도
  timeGapHours Float? // 원본 발행 후 몇 시간 뒤 복사?
  evidence     String?        @db.Text // 판단 근거
  detectedAt   DateTime       @default(now())

  @@unique([sourceFactId, targetFactId])
  @@index([targetFactId])
  @@index([relationType])
}

// ═══ v3.1: 외부 정정 DB 연동 ═══
model ExternalRetractionSource {
  id                String    @id @default(cuid())
  providerName      String    @unique // "retraction_watch", "kpcc" (언론중재위), "snopes"
  baseUrl           String
  apiKey            String? // 필요 시
  active            Boolean   @default(true)
  domain            String // medical/news/general
  lastSyncAt        DateTime?
  syncIntervalHours Int       @default(24)
  createdAt         DateTime  @default(now())
}

// ═══ v3.1: 정치 도메인 편향 감지 ═══
model BiasDetection {
  id             String        @id @default(cuid())
  factId         String
  fact           KnowledgeFact @relation(fields: [factId], references: [id], onDelete: Cascade)
  method         String // 'lexicon', 'source_based', 'llm'
  biasScore      Float // -1 ~ +1
  biasLabel      BiasLabel
  confidence     Float         @default(0.7)
  triggerPhrases String[] // 편향 판단 근거 문구
  detectedAt     DateTime      @default(now())
  verifiedBy     String? // admin 검증
  verifiedAt     DateTime?

  @@index([factId, detectedAt])
  @@index([biasLabel, confidence])
}

// ═══ v3.1: 언론사 편향 레지스트리 ═══
model MediaBiasProfile {
  id               String    @id @default(cuid())
  mediaOutlet      String    @unique // "chosun", "hani", "ohmynews"
  displayName      String
  domain           String? // 매칭용 URL 도메인
  biasScore        Float // 전체 편향 점수
  biasLabel        BiasLabel
  factualityRating String // "high", "mixed", "low"
  sources          String[] // 참조한 외부 분석 (AllSides, MBFC 등)
  notes            String?   @db.Text
  updatedAt        DateTime  @updatedAt
}

// ═══ v3.1: 번역 관계 테이블 (세부 추적) ═══
model TranslationLink {
  id                String   @id @default(cuid())
  sourceFactId      String // 번역본
  targetFactId      String // 원문
  sourceLang        String
  targetLang        String
  translationMethod String // "human", "machine", "ai_llm", "unknown"
  confidence        Float // 번역 원본 추정 신뢰도
  textSimilarity    Float? // 교차언어 임베딩 유사도
  detectedAt        DateTime @default(now())

  @@unique([sourceFactId, targetFactId])
  @@index([sourceLang, targetLang])
}

// ═══ v3.1: 미디어 사실 메타데이터 ═══
model MediaFact {
  id                String        @id @default(cuid())
  factId            String        @unique
  fact              KnowledgeFact @relation("KnowledgeFactMedia", fields: [factId], references: [id], onDelete: Cascade)
  mediaType         MediaType
  fileUrl           String
  thumbnailUrl      String?
  perceptualHash    String // pHash/dHash
  simHash           String? // 시각 simhash 64bit
  ocrText           String?       @db.Text // 이미지에서 추출한 텍스트
  transcription     String?       @db.Text // 영상/오디오 스크립트
  detectedObjects   String[] // 객체 감지 결과 (광고/로고/얼굴 등)
  deepfakeScore     Float? // 딥페이크 의심도 0~1
  manipulationFlags String[] // crop, edit, filter 등
  originalSize      Int? // 바이트
  duration          Float? // 초 (영상/오디오)
  resolution        String? // "1920x1080"
  exifData          Json?
  createdAt         DateTime      @default(now())

  @@index([perceptualHash])
  @@index([deepfakeScore])
}

// ═══ v3.2: 8가지 추가 개선 ═══

// ① 실시간 철회 알림 — 과거 답변이 지금 보니 틀렸을 때
model RetractionNotification {
  id                       String    @id @default(cuid())
  userId                   String
  affectedAnswerEvidenceId String? // AnswerEvidence 참조 (해당 답변)
  retractedFactId          String // 어떤 사실이 철회됐는지
  retractionEventId        String // RetractionEvent 참조
  message                  String    @db.Text
  notified                 Boolean   @default(false)
  notifiedAt               DateTime?
  acknowledged             Boolean   @default(false)
  acknowledgedAt           DateTime?
  createdAt                DateTime  @default(now())

  @@index([userId, acknowledged])
  @@index([notified])
}

// ② Adversarial Fact Injection 테스트
model AdversarialTestCase {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.Text
  category          String // 'false_news', 'biased_wording', 'copy_spam', 'deepfake', 'mistranslation'
  injection         Json // 주입할 가짜 사실 데이터
  expectedDetection String // 'should_reject', 'should_flag', 'should_downgrade'
  lastRunAt         DateTime?
  lastResult        String? // 'passed', 'failed', 'inconclusive'
  runHistory        Json? // 최근 실행 결과들
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())

  @@index([category, active])
}

model AdversarialTestRun {
  id             String    @id @default(cuid())
  testCaseId     String
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  result         String // 'passed', 'failed', 'inconclusive'
  details        Json
  factIdsCreated String[] // 테스트 중 생성된 fact ids (정리용)

  @@index([testCaseId, startedAt])
}

// ④ 논리적 무결성 (삼단논법 / 논리 모순)
model LogicalInconsistency {
  id                String    @id @default(cuid())
  factIds           String[] // 관련 사실들 (2개 이상)
  inconsistencyType String // 'syllogism_violation', 'direct_contradiction', 'transitivity_break', 'quantifier_mismatch'
  explanation       String    @db.Text
  severity          String    @default("medium") // 'low', 'medium', 'high', 'critical'
  detectionMethod   String // 'symbolic', 'llm', 'hybrid'
  resolved          Boolean   @default(false)
  resolution        String?   @db.Text
  detectedAt        DateTime  @default(now())
  resolvedAt        DateTime?
  resolvedBy        String?

  @@index([resolved, severity])
  @@index([inconsistencyType])
}

// ⑤ 사용자 편향 캘리브레이션
model UserBiasCalibration {
  id                String   @id @default(cuid())
  userId            String   @unique
  preferredSpectrum String   @default("centrist") // 'progressive', 'moderate', 'centrist', 'conservative'
  toleranceRange    Float    @default(0.3) // 허용 편차 0~1
  showOpposing      Boolean  @default(true) // 반대 관점 강제 노출
  guardrailMode     String   @default("balanced") // 'off', 'balanced' (30% 이상 반대 강제), 'strict' (극단 차단)
  preferences       Json? // 세부 설정 (도메인별 등)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

// ⑥ Time Machine — 시점 스냅샷
model KnowledgeSnapshot {
  id                String    @id @default(cuid())
  name              String // "2026-04-23 법률 스냅샷"
  snapshotAt        DateTime // 스냅샷 기준 시점
  scope             String // 'full', 'domain', 'entity'
  scopeValue        String? // domain명 또는 entity명
  factCount         Int
  merkleRoot        String // 무결성 해시
  storageLocation   String // 파일 경로 또는 외부 저장소 URL
  compressionMethod String    @default("gzip")
  sizeBytes         BigInt?
  createdBy         String?
  createdAt         DateTime  @default(now())
  expiresAt         DateTime?

  @@index([snapshotAt])
  @@index([scope, scopeValue])
}

// ⑦ Federated Fact Check — 외부 HLKM 인스턴스와 교차 검증
model FederatedInstance {
  id              String    @id @default(cuid())
  instanceId      String    @unique // UUID 또는 도메인
  name            String
  apiUrl          String
  publicKey       String    @db.Text
  organization    String?
  trustLevel      Float     @default(0.5) // 0~1, 상호 신뢰도
  active          Boolean   @default(true)
  lastHandshakeAt DateTime?
  syncsCompleted  Int       @default(0)
  createdAt       DateTime  @default(now())
}

model FederatedQuery {
  id         String    @id @default(cuid())
  instanceId String
  factId     String? // 조회 대상 사실
  entity     String? // 또는 entity
  query      String
  sentAt     DateTime  @default(now())
  receivedAt DateTime?
  response   Json? // 원격 HLKM 응답
  agreement  Float? // 0~1, 원격 측과의 일치도
  status     String    @default("pending") // pending, completed, failed

  @@index([instanceId, sentAt])
  @@index([status])
}

// ═══ KYC 게이트 정책 — 핵심 ═══
// 모든 지식 기여는 KYC 필수. 미인증 사용자는 LLM 학습 데이터 수집만.

// 미인증 사용자 / 인증 사용자 공통의 LLM 학습 로그
// 지식 그래프(KnowledgeFact)와 완전히 분리된 저장소
model LLMTrainingLog {
  id             String  @id @default(cuid())
  userId         String? // 로그인 안 했으면 null
  userIsVerified Boolean @default(false) // 수집 시점 KYC 여부
  sessionId      String? // 세션 기반 익명 식별

  // 대화 내용
  userMessage    String  @db.Text
  assistantReply String  @db.Text
  conversationId String?
  model          String? // 사용된 LLM 모델

  // 메타
  domain         String?
  language       String  @default("ko")
  feedbackRating String? // 'positive', 'negative', null
  feedbackNote   String? @db.Text

  // 품질 플래그 (학습 전 필터링용)
  containsPII         Boolean   @default(false)
  containsHarmful     Boolean   @default(false)
  qualityScore        Float?
  reviewedForTraining Boolean   @default(false)
  approvedForTraining Boolean   @default(false) // 관리자 승인 후 학습 파이프라인에 편입
  approvedAt          DateTime?
  approvedBy          String?

  // 보존 정책
  createdAt DateTime  @default(now())
  expiresAt DateTime? // 미인증자: 예) 90일 후 삭제

  @@index([userId, createdAt])
  @@index([approvedForTraining, createdAt])
  @@index([userIsVerified, createdAt])
}

// 차단 기록 (미인증자가 기여 시도한 경우)
model ContributionGateDenial {
  id              String   @id @default(cuid())
  userId          String?
  sessionId       String?
  attemptedAction String // 'ingest_fact', 'peer_review', 'dispute_initiate', 'bounty_create', 'prediction_bet'
  reason          String // 'kyc_required', 'suspended', 'tier_insufficient', 'quota_exceeded'
  payloadDigest   String? // 시도한 내용 해시 (복구용)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([reason, createdAt])
}

// ═══ v3.3 크라우드소싱 거버넌스 (10 테이블) ═══

// 기여자 프로필 (Tier / 평판 / 스테이킹 잔액)
model ContributorProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  tier             ContributorTier @default(BRONZE)
  reputation       Float           @default(0.5) // 0~1
  stakedBalance    Int             @default(0) // 스테이킹 중인 토큰
  lifetimeStaked   BigInt          @default(0)
  lifetimeSlashed  BigInt          @default(0)
  correctContribs  Int             @default(0)
  wrongContribs    Int             @default(0)
  totalEarned      BigInt          @default(0)
  kycVerified      Boolean         @default(false)
  kycMethod        String? // 'ipin', 'passport', 'worldid', 'brightid'
  kycVerifiedAt    DateTime?
  expertTags       String[] // ['law', 'medical:cardiology'] 등
  lastActiveAt     DateTime?
  createdAt        DateTime        @default(now())
  suspensionReason String?
  suspendedUntil   DateTime?

  @@index([tier, reputation])
  @@index([kycVerified])
}

enum ContributorTier {
  BRONZE // 신규
  SILVER // 검증된 기본 기여자
  GOLD // 민감 도메인 기여 가능
  DIAMOND // 거버넌스 투표 가능
  SUSPENDED // 정지 상태
}

// Stake-to-Contribute (기여 시 스테이킹)
model ContributionStake {
  id               String    @id @default(cuid())
  factId           String // 기여한 사실
  userId           String // 기여자
  stakedAmount     Int // 걸린 토큰
  status           String    @default("pending") // pending, settled_correct, slashed, partial_slash
  settledAt        DateTime?
  slashedAmount    Int       @default(0)
  rewardedAmount   Int       @default(0)
  peerReviewPassed Boolean? // null=미검토, true=통과, false=실패
  createdAt        DateTime  @default(now())

  @@index([userId, status])
  @@index([factId])
  @@index([status, createdAt])
}

// Peer Review 투표
model PeerReview {
  id             String    @id @default(cuid())
  factId         String
  reviewerId     String
  vote           String // 'accept', 'reject', 'abstain'
  stakedAmount   Int // 리뷰어도 스테이킹
  rationale      String?   @db.Text
  confidence     Float     @default(0.7)
  finalizedAt    DateTime?
  rewardedAmount Int       @default(0)
  slashedAmount  Int       @default(0)
  createdAt      DateTime  @default(now())

  @@unique([factId, reviewerId])
  @@index([factId])
  @@index([reviewerId, createdAt])
}

// Dispute (논쟁) DAO
model Dispute {
  id             String        @id @default(cuid())
  relatedFactIds String[] // 관련 사실들
  topic          String
  description    String        @db.Text
  initiatorId    String
  status         String        @default("open") // open, voting, resolved, invalid
  votingEndsAt   DateTime
  winningSide    String? // 'A', 'B', 'both_invalid', 'coexist'
  totalStaked    Int           @default(0)
  votes          DisputeVote[]
  resolvedAt     DateTime?
  resolutionNote String?       @db.Text
  createdAt      DateTime      @default(now())

  @@index([status, votingEndsAt])
}

model DisputeVote {
  id            String   @id @default(cuid())
  disputeId     String
  dispute       Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  voterId       String
  side          String // 'A', 'B', 'both_invalid', 'coexist'
  stakedAmount  Int
  rationale     String?  @db.Text
  settledAmount Int? // 승리 시 수령, 패배 시 슬래시
  createdAt     DateTime @default(now())

  @@unique([disputeId, voterId])
  @@index([disputeId])
}

// 전문가 자격 증명
model ExpertCredential {
  id               String    @id @default(cuid())
  userId           String
  field            String // 'law', 'medical:cardiology', 'tax', ...
  organization     String? // '대한변호사협회', '서울대병원'
  licenseNumber    String?
  documentUrl      String? // 업로드된 증빙
  verifiedBy       String // 'admin', 'third_party', 'ocr_auto'
  verifiedAt       DateTime?
  expiresAt        DateTime?
  status           String    @default("pending") // pending, verified, rejected, expired
  weightMultiplier Float     @default(1.0) // 해당 field에서 기여 가중치
  createdAt        DateTime  @default(now())

  @@index([userId, field])
  @@index([status])
}

// Sybil 탐지 플래그
model SybilFlag {
  id             String    @id @default(cuid())
  userId         String
  pattern        String // 'ip_cluster', 'behavioral', 'device_fingerprint', 'temporal'
  severity       String    @default("medium") // 'low', 'medium', 'high', 'critical'
  detectedAt     DateTime  @default(now())
  evidence       Json // 판단 근거
  relatedUserIds String[] // 같은 클러스터로 의심되는 계정들
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?
  resolution     String? // 'confirmed_sybil', 'false_positive', 'warning_issued'

  @@index([userId, resolved])
  @@index([severity, resolved])
}

// KYC / Proof of Personhood
model PersonhoodVerification {
  id            String    @id @default(cuid())
  userId        String    @unique
  method        String // 'ipin', 'worldid', 'brightid', 'proofofhumanity', 'manual'
  providerId    String? // 외부 제공자의 uniqueness id (해시)
  proof         String?   @db.Text // 증명 토큰 (유효성 검증용)
  verifiedAt    DateTime  @default(now())
  expiresAt     DateTime?
  revoked       Boolean   @default(false)
  revokedReason String?

  @@index([method, verifiedAt])
}

// Bounty (지식 현상금) 시장
model Bounty {
  id           String             @id @default(cuid())
  creatorId    String
  topic        String
  description  String             @db.Text
  domain       String?
  rewardAmount Int // 걸린 토큰
  requiredTier ContributorTier    @default(SILVER) // 최소 기여자 등급
  deadline     DateTime
  status       String             @default("open") // open, awarded, expired, cancelled
  winnerId     String?
  winnerFactId String?
  submissions  BountySubmission[]
  createdAt    DateTime           @default(now())
  awardedAt    DateTime?

  @@index([status, deadline])
  @@index([domain, status])
}

model BountySubmission {
  id             String   @id @default(cuid())
  bountyId       String
  bounty         Bounty   @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  contributorId  String
  factId         String
  submissionNote String?  @db.Text
  score          Float? // 심사 점수 0~1
  selected       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([bountyId, factId])
  @@index([bountyId, score])
}

// Prediction Market (미래 사실 베팅)
model PredictionMarket {
  id             String      @id @default(cuid())
  pendingFactId  String      @unique // PENDING 상태 fact
  question       String      @db.Text
  yesPool        BigInt      @default(0) // YES 측 토큰 총량
  noPool         BigInt      @default(0)
  bettersCount   Int         @default(0)
  resolutionDate DateTime // 결과 확정 예정일
  resolved       Boolean     @default(false)
  outcome        String? // 'YES', 'NO', 'INVALID'
  resolvedAt     DateTime?
  bets           MarketBet[]
  createdAt      DateTime    @default(now())

  @@index([resolved, resolutionDate])
}

model MarketBet {
  id        String           @id @default(cuid())
  marketId  String
  market    PredictionMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userId    String
  side      String // 'YES', 'NO'
  amount    Int
  payoff    Int? // 정산된 보상 (음수 = 손실)
  settledAt DateTime?
  createdAt DateTime         @default(now())

  @@index([marketId, userId])
  @@index([userId, createdAt])
}

// 원자 주장 분해 (⑤ Claim Decomposition)
model DecomposedClaim {
  id                 String   @id @default(cuid())
  parentFactId       String // 원본 뉴스/사실
  atomicStatement    String   @db.Text // 원자적 주장
  claimType          String // numeric/date/attribution/causal/qualitative
  verifiableValue    String?  @db.Text // 검증 가능한 값
  verificationStatus String   @default("pending") // pending/verified/refuted/unverifiable
  verifiedByFactId   String? // 이 주장을 지지/반박하는 다른 사실
  confidence         Float    @default(0.5)
  extractedAt        DateTime @default(now())

  @@index([parentFactId])
  @@index([verificationStatus])
}

// ============================================================
// Hwarang Grid 분산 학습 (HFL Round / Peer Vote / Earnings / Data Shard)
// ============================================================

model Round {
  id                 String      @id @default(cuid())
  domain             String? // "code", "legal", "tax", null=general
  status             RoundStatus @default(OPEN)
  config             Json // {lora_r, alpha, lr, steps_per_round, ...}
  validationFraction Float       @default(0.15) // peer 평가용 데이터 비율
  createdAt          DateTime    @default(now())
  startedAt          DateTime?
  completedAt        DateTime?

  // 라운드 종료 후 hold-out 평가 (code_round_quality.validate_completed_round)
  qualityScore  Float? // 새 LoRA 평가 점수 (0~1)
  baselineScore Float? // 직전 라운드 LoRA 점수 (롤백 판단용)
  accepted      Boolean? // qualityScore > baselineScore 면 true, 아니면 롤백

  participants RoundParticipant[]
  shards       DataShard[]
  votes        PeerVote[]
  earnings     AgentEarnings[]

  @@index([status, createdAt(sort: Desc)])
  @@index([domain, status])
  @@index([domain, status, qualityScore])
}

enum RoundStatus {
  OPEN
  RUNNING
  COMPLETED
  FAILED
}

model RoundParticipant {
  id           String                 @id @default(cuid())
  roundId      String
  round        Round                  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  agentId      String
  status       RoundParticipantStatus @default(INVITED)
  shardId      String? // DataShard.id
  joinedAt     DateTime               @default(now())
  submittedAt  DateTime?
  qualityScore Float? // peer 평균 점수

  @@unique([roundId, agentId])
  @@index([agentId, status])
  @@index([roundId, status])
}

enum RoundParticipantStatus {
  INVITED
  ACCEPTED
  SUBMITTED
  REJECTED
  TIMEOUT
}

model PeerVote {
  id           String   @id @default(cuid())
  roundId      String
  round        Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  voterId      String // 투표하는 agent_id
  peerId       String // 평가받는 agent_id
  qualityScore Float // 0~1
  rationale    String?  @db.Text
  createdAt    DateTime @default(now())

  @@unique([roundId, voterId, peerId])
  @@index([roundId, peerId])
  @@index([voterId, createdAt(sort: Desc)])
}

model AgentEarnings {
  id        String              @id @default(cuid())
  agentId   String
  roundId   String?
  round     Round?              @relation(fields: [roundId], references: [id], onDelete: SetNull)
  amount    Float // HWR 토큰 (소수 가능)
  source    AgentEarningsSource
  metadata  Json?
  createdAt DateTime            @default(now())

  @@index([agentId, createdAt(sort: Desc)])
  @@index([roundId])
  @@index([source, createdAt(sort: Desc)])
}

enum AgentEarningsSource {
  HFL_REWARD // 라운드 학습 기여 보상
  PEER_BONUS // peer 평가 가산점
  DATA_UPLOAD // 데이터 업로드 보상
  REFERRAL // 추천 보너스
  MANUAL // 관리자 지급
}

model DataShard {
  id           String   @id @default(cuid())
  roundId      String
  round        Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  shardIdx     Int // 라운드 내 shard 인덱스
  dataUrl      String // 다운로드 URL 또는 경로
  sizeBytes    BigInt   @default(0)
  sampleCount  Int      @default(0)
  isValidation Boolean  @default(false) // peer 평가용 shard 여부
  checksum     String? // sha256
  createdAt    DateTime @default(now())

  @@unique([roundId, shardIdx])
  @@index([roundId, isValidation])
}

// ============================================================
// HSEE Phase 1 — Compounding Loop (자기개선 복리 루프)
// ============================================================

// 채팅 응답 1 회당 1 행. 명시(rating) + 암묵(followup_msg, edit_distance) 신호를
// 합쳐서 isSatisfied 로 정규화. HFL 라운드 자동 트리거 입력.
model RLHFFeedback {
  id             String    @id @default(cuid())
  conversationId String?
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId      String?   @unique
  domain         String? // 라우팅된 도메인 (law/code/medical/general …)
  modelName      String? // 실제 사용된 모델
  loraName       String? // LoRA 사용 여부 (없으면 NULL)
  rating         Int? // -1, 0, 1 (👎 / 없음 / 👍)
  ratedAt        DateTime? // 명시 피드백이 들어온 시각
  editDistance   Float? // 사용자가 응답을 수정해서 다시 보냈으면 정규화 거리
  followupMsg    String?   @db.Text // 같은 대화의 다음 user 메시지 (암묵 신호 추출용)
  isSatisfied    Boolean? // 종합 점수 → 이진 (positive: true, negative: false, 미정: null)
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([domain, isSatisfied])
  @@index([domain, createdAt])
}

// 도메인×모델 단위 1 시간 윈도우 누적. HNTL 라우터가 도메인 가중치 조정 시 입력.
model RoutingStats {
  id                String    @id @default(cuid())
  domain            String
  modelName         String
  totalRequests     Int       @default(0)
  totalLatencyMs    BigInt    @default(0)
  satisfactionSum   Float     @default(0) // -1 ~ 1 누적합
  satisfactionCount Int       @default(0) // 만족도 신호가 있었던 요청 수
  windowStart       DateTime  @default(now()) // 1 시간 단위 floor
  windowEnd         DateTime?

  @@unique([domain, modelName, windowStart])
  @@index([domain, windowStart(sort: Desc)])
  @@index([modelName, windowStart(sort: Desc)])
}

// GDPR 삭제 요청 (⑩ Right-to-be-Forgotten)
model ForgetRequest {
  id            String    @id @default(cuid())
  userId        String // 삭제 요청자
  scope         String // "all_private", "specific_facts", "contributions"
  targetFactIds String[] // scope=specific_facts 일 때
  reason        String?   @db.Text
  status        String    @default("pending") // pending, approved, completed, rejected
  requestedAt   DateTime  @default(now())
  processedAt   DateTime?
  processedBy   String?
  reportUrl     String? // 처리 완료 리포트 (감사 목적)

  @@index([userId, requestedAt])
  @@index([status])
}

// ============================================================
// Trusted Source Network — 화이트리스트 출처 + Cross-Verification
// ============================================================
//
// 화랑은 무차별 크롤링 대신, 관리자 승인 화이트리스트만 크롤링하고
// 출처별 신뢰도(trustLevel)로 가중 합산해 사실 검증 점수를 낸다.
// 1차 출처(law.go.kr 등)는 isPrimarySource 로 표시되어, 이들이 반박하면
// confidence 가 강제로 떨어진다.
model TrustedSource {
  id          String  @id @default(cuid())
  domain      String  @unique
  displayName String
  type        String // government, academic, news_major, news_minor, fact_checker, medical, financial

  // 관리자 평가
  trustLevel      Int // 0~100
  isWhitelisted   Boolean @default(true)
  isPrimarySource Boolean @default(false)
  isActive        Boolean @default(true)

  // 도메인 전문성 — 매칭에 쓰이는 태그들
  domains String[]

  // 크롤링 설정
  crawlSchedule String  @default("0 */6 * * *")
  crawlMethod   String  @default("rss") // rss | sitemap | api | scraper | none
  rssUrl        String?
  apiEndpoint   String?
  apiKey        String?
  selectorJson  Json?

  // 통계
  totalCrawled       Int       @default(0)
  totalFacts         Int       @default(0)
  successRate        Float     @default(1.0)
  lastCrawledAt      DateTime?
  contradictionCount Int       @default(0)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facts     SourceCitation[]
  crawlJobs CrawlJob[]

  @@index([trustLevel, isWhitelisted])
  @@index([type, isWhitelisted])
}

model SourceCitation {
  id          String        @id @default(cuid())
  factId      String? // KnowledgeFact 와 연결 (옵션)
  sourceId    String
  source      TrustedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  url         String
  title       String?
  excerpt     String?       @db.Text
  publishedAt DateTime?
  crawledAt   DateTime      @default(now())

  @@index([factId])
  @@index([sourceId, crawledAt])
  @@index([url])
}

// ============================================================
// HSEE Phase 2 — Online Continual Learning (EWC + Replay)
// ============================================================

// 학습 잡 큐 — auto_trainer.maybe_enqueue_training 가 push, process_queue 가 pop
model TrainingJob {
  id        String @id @default(cuid())
  domain    String
  loraName  String // 학습 대상 LoRA
  baseModel String // 베이스 모델 (vLLM backendId)

  // 데이터 / 하이퍼파라미터
  sampleCount Int   @default(0)
  ewcLambda   Float @default(1000.0) // EWC 정규화 강도
  replayRatio Float @default(0.3) // 신규:리플레이 비율 (replay 비중)

  // 상태
  status       String    @default("queued") // queued|running|done|failed
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?

  // 결과
  newAdapterPath  String?
  forgettingScore Float? // 0~1, 낮을수록 좋음
  qualityScore    Float? // 새 도메인 품질 (0~1)

  // 메타
  triggeredBy String? // "auto" | "manual" | userId
  createdAt   DateTime @default(now())

  @@index([domain, status])
  @@index([status, createdAt])
}

// EWC 의 핵심 — 옛 task 의 Fisher 정보 행렬 + 최적 가중치 스냅샷
model FisherSnapshot {
  id       String @id @default(cuid())
  loraName String
  domain   String

  // 디스크에 저장 (큰 텐서이므로 path 만 DB)
  fisherPath  String // Fisher 정보 행렬 (대각 근사) .pt
  optimalPath String // 최적 LoRA 가중치 스냅샷 .pt

  // 메타
  taskCount  Int // 누적 학습 task 수
  computedAt DateTime @default(now())

  @@unique([loraName, domain])
}

// Priority Replay Buffer — 학습 시 옛 샘플 재사용
model ReplaySample {
  id             String @id @default(cuid())
  domain         String
  prompt         String @db.Text
  expectedOutput String @db.Text

  // 우선순위 신호
  priority   Float @default(1.0) // EWC 중요도 + RLHF 평점 + 다양성
  difficulty Float? // 모델이 틀렸는지 (0=쉬움, 1=어려움)
  rlhfRating Int? // -1, 0, 1

  // 샘플링 추적
  sampledCount  Int       @default(0)
  lastSampledAt DateTime?

  createdAt DateTime @default(now())

  @@index([domain, priority])
  @@index([domain, lastSampledAt])
}

// ============================================================
// HSEE Phase 3 — Self-Growing Architecture
// ============================================================
// 도메인별 능력 측정 — capability_monitor 가 매일 1 회 기록
model CapabilityMetric {
  id       String  @id @default(cuid())
  domain   String
  loraName String?

  // 측정 시점 / 윈도우
  measuredAt  DateTime @default(now())
  windowStart DateTime
  windowEnd   DateTime

  // 메트릭
  benchmarkScore    Float? // 0~1, 자체 벤치마크 정확도
  satisfactionAvg   Float? // RLHFFeedback.isSatisfied 평균 (0~1)
  factualAccuracy   Float? // SourceCitation 결합 confidence
  responseLatencyMs Float?

  // 한계 신호
  failureRate   Float @default(0.0) // 답변 거부 / 폴백 비율
  unmatchedRate Float @default(0.0) // 도메인 미매칭 (general 폴백) 비율

  sampleCount Int @default(0)

  @@index([domain, measuredAt])
}

// 성장 결정 큐 — auto_spawn / scale_decision 가 제안, 관리자가 승인
model GrowthDecision {
  id String @id @default(cuid())

  // "spawn_lora" | "scale_base" | "expand_lora_rank" | "split_domain"
  decisionType String

  // 트리거 신호
  triggerDomain String?
  // "low_satisfaction" | "high_unmatched" | "low_factual_accuracy" |
  // "high_failure_rate" | "emergent_domain" | "global_quality_low"
  triggerMetric String?
  triggerValue  Float?

  // 결정 상태 — proposed | approved | executing | done | rejected
  status       String @default("proposed")
  proposalJson Json // 구체 액션 (예: {domain, min_samples, target_rank ...})

  // 사람 검토
  reviewedBy   String?
  reviewedAt   DateTime?
  rejectReason String?

  // 결과
  executedAt DateTime?
  resultJson Json?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([decisionType, status])
  @@index([triggerDomain, status])
}

// 미분류 질문 클러스터링으로 발견된 새 도메인 후보
model EmergentDomain {
  id            String  @id @default(cuid())
  candidateName String  @unique // "robotics", "philosophy" 등 영문 1단어
  description   String?

  // 클러스터링 결과
  centroidEmbedding String? @db.Text // pgvector 도입 전 임시 (hex encoded)
  exampleQueries    String[] @default([]) // 대표 질문 (5 개 내외)
  sampleCount       Int      @default(0)

  // 정식 도메인 승격
  isPromoted  Boolean   @default(false)
  promotedAt  DateTime?

  firstSeenAt   DateTime @default(now())
  lastUpdatedAt DateTime @updatedAt

  @@index([isPromoted, sampleCount])
}

// ============================================================
// 분산 크롤 잡 큐 (Phase 4.1)
// 마스터=디스패처가 CrawlJob 을 생성하고, 에이전트가 lease 로 가져가서 처리.
// 같은 (sourceId, url) 중복은 unique 제약으로 자동 방지.
// 같은 URL 을 두 에이전트가 동시에 안 가져가도록 leasedBy/leaseExpiresAt 으로
// atomic 임대 (status: pending → leased) 한다.
// ============================================================

model CrawlJob {
  id       String        @id @default(cuid())
  sourceId String
  source   TrustedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  // 작업 내용
  url      String
  jobType  String // "rss_item" | "sitemap_url" | "api_query" | "page_extract"
  metadata Json? // RSS title/summary, sitemap lastmod, API params 등

  // 상태
  status String @default("pending") // pending | leased | completed | failed | expired

  // Lease (분산 락)
  leasedBy       String? // agent_id
  leasedAt       DateTime?
  leaseExpiresAt DateTime?

  // 시도
  attemptCount Int     @default(0)
  maxAttempts  Int     @default(3)
  lastError    String?

  // 결과
  resultJson Json? // 에이전트가 보낸 추출 결과 (title, content, publishedAt)
  factId     String? // HLKM 에 ingest 된 fact id

  // 메타
  priority    Int       @default(0) // 높을수록 먼저
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@unique([sourceId, url]) // 같은 source+url 중복 방지
  @@index([status, priority, createdAt])
  @@index([sourceId, status])
  @@index([leasedBy, leaseExpiresAt])
}

// 에이전트별 크롤 통계 / 신뢰 가중치
model CrawlAgentStats {
  id      String @id @default(cuid())
  agentId String @unique

  // 누적
  totalLeased    Int @default(0)
  totalCompleted Int @default(0)
  totalFailed    Int @default(0)
  totalExpired   Int @default(0)

  // 최근
  lastLeasedAt    DateTime?
  lastCompletedAt DateTime?
  avgLatencyMs    Float     @default(0)

  // 가중치
  trustWeight Float   @default(1.0) // 1.0 기본, 신뢰도 높으면 우선 분배
  isBlocked   Boolean @default(false)

  @@index([trustWeight, isBlocked])
}

// ============================================================
// Research Engine — arXiv / OpenReview / ACL Anthology 매일 수집
// ============================================================

model Paper {
  id              String   @id @default(cuid())
  arxivId         String?  @unique // "2404.16710"
  doi             String?
  source          String // "arxiv", "openreview", "aclanthology"

  title           String
  authors         String[]
  affiliation     String?
  abstract        String   @db.Text

  // 구조화
  contribution        String? @db.Text // 1줄 핵심 기여
  methodSummary       String? @db.Text // 5줄 method 요약
  experimentalResults Json?
  codeUrl             String? // GitHub 링크

  // 메타
  categories  String[] // cs.AI, cs.CL 등
  keywords    String[]
  publishedAt DateTime
  pdfUrl      String

  // 평가
  citationCount      Int      @default(0)
  applicabilityScore Float? // 화랑 적용 가능성 0~1
  applicableModules  String[] // ["HSEE Phase 2", "HNTL"]
  difficulty         String? // easy/medium/hard
  estimatedROI       String? // low/medium/high

  // 한국어 요약
  koreanSummary String? @db.Text

  // 처리 상태
  status        String    @default("pending") // pending|parsed|summarized|applied|rejected
  parsedAt      DateTime?
  summarizedAt  DateTime?

  // HLKM 연결
  factId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications PaperApplication[]

  @@index([source, publishedAt])
  @@index([status, applicabilityScore])
  @@index([categories])
}

model PaperApplication {
  id      String @id @default(cuid())
  paperId String
  paper   Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)

  module      String // 적용할 화랑 모듈
  description String @db.Text // 어떻게 적용할지

  status           String  @default("proposed") // proposed|approved|implementing|done|rejected
  growthDecisionId String? // GrowthDecision 과 연결

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  reviewedBy String?

  @@index([status])
}

model PaperTrend {
  id        String   @id @default(cuid())
  weekStart DateTime

  keyword     String
  paperCount  Int
  velocityPct Float // 전 주 대비 증가율 %
  topPapers   String[] // top 5 paper IDs

  isEmerging Boolean @default(false) // 30%+ 증가 시

  createdAt DateTime @default(now())

  @@unique([weekStart, keyword])
  @@index([weekStart, velocityPct])
}

// ============================================================
// Code Engine — 블로그/SO 글에서 추출한 재사용 가능 코드 패턴
// ============================================================
//
// 카테고리 enum (string):
//   - hook            : React/Vue/Svelte 등 hook 패턴
//   - utility         : 범용 유틸리티 함수 (debounce, retry, ...)
//   - architecture    : 시스템/모듈 구조 (event-sourcing, CQRS, ...)
//   - antipattern     : 피해야 할 패턴
//   - optimization    : 성능 최적화 기법
//   - design_pattern  : 전통적 GoF 등 디자인 패턴
//
// 출처: code_pattern_extractor.py 가 dev_source_crawler 가 수집한
// KnowledgeFact(domain="code") 들을 LLM 으로 분류해서 채움.
model CodePattern {
  id          String  @id @default(cuid())
  patternName String
  category    String // hook | utility | architecture | antipattern | optimization | design_pattern
  language    String?
  framework   String?

  summary String  @db.Text
  useCase String? @db.Text

  // 원본 KnowledgeFact 와 약하게 연결 (FK 아님 — fact 가 archive 돼도 패턴은 유지)
  sourceFactId String?
  sourceUrl    String?

  // 평판
  popularity   Int    @default(0) // 다른 글에서 인용된 횟수
  qualityScore Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, language])
  @@index([popularity])
}

// ============================================================
// Code Quality Pipeline — KnowledgeFact → 학습용 Q&A 페어
// ============================================================
//
// research/quality/code_pair_builder.py 가 high_quality 인 KnowledgeFact 를
// 자연어 질문 + 정답 코드 페어로 변환해서 저장. code_executor 가 실행 검증
// 후 executionStatus 를 채운다. LoRA 학습 시 isUsedInLora 가 false 이고
// executionStatus 가 passed/syntax_only 인 페어만 골라 데이터셋으로 export.
model CodePair {
  id String @id @default(cuid())

  instruction String  @db.Text // 사용자 질문 (자연어)
  response    String  @db.Text // 정답 코드 (마크다운 fence 포함)
  language    String?
  framework   String?
  category    String? // hook|utility|api|component|algorithm|test

  // 출처 (KnowledgeFact 와 느슨한 연결)
  sourceFactId String?

  // 검증
  executionStatus    String  @default("untested") // untested|passed|failed|timeout|syntax_only|no_code|error|sandbox_unavailable
  executionLog       String? @db.Text
  executionRuntime   String? // docker | firejail | subprocess | none
  executionElapsedMs Int?

  // 학습 메타
  qualityScore Float?
  isUsedInLora Boolean @default(false)
  loraRound    Int?

  // 평가셋 전용 — 학습에 안 씀. eval_set_builder.py 가 주기적으로 마킹.
  // True 인 페어는 라운드 간 변경되지 않아 LoRA 비교 평가의 기준이 된다.
  isEvaluation Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([executionStatus, qualityScore])
  @@index([language, framework])
  @@index([isUsedInLora])
  @@index([isEvaluation])
}

// ============================================================
// Design Engine — 디자인 글/사이트에서 추출한 시각 패턴
// ============================================================
//
// 분류 차원:
//   - trendKeywords   : minimalism / brutalism / glassmorphism …
//   - layoutCategory  : hero / grid / split / asymmetric / magazine / fullscreen
//   - colorMood       : warm / cool / monochrome / vibrant / muted
//   - typographyStyle : serif / sans / display / monospace / mixed
//   - applicableTo    : landing / dashboard / mobile_app / marketing …
//
// 출처: design_pattern_extractor.py 가 design_source_crawler 가 수집한
// KnowledgeFact(domain="design") 들을 LLM 으로 분류해서 채움.
model DesignPattern {
  id String @id @default(cuid())

  trendKeywords   String[] // minimalism, brutalism 등
  layoutCategory  String // hero | grid | split | asymmetric | magazine | fullscreen
  colorMood       String? // warm | cool | monochrome | vibrant | muted
  typographyStyle String? // serif | sans | display | monospace | mixed

  summary      String   @db.Text
  applicableTo String[] // landing, dashboard, mobile_app

  // 원본 KnowledgeFact 와 약하게 연결 (FK 아님)
  sourceFactId String?
  sourceUrl    String?

  popularity Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([layoutCategory])
  @@index([popularity])
}

// ============================================================
// Tech Trend — 주간 코드/디자인 키워드 빈도 + emerging 감지
// ============================================================
//
// PaperTrend 와 별도 모델 — 도메인 (code | design) 이 다르고
// 키워드 추출 로직 (KNOWN_TECH_KEYWORDS / DesignPattern.trendKeywords) 도 다름.
//
// 매주 일요일 22:00 KST cron (tech_trend_tracker.weekly_tech_trends_full_cycle):
//   1. 지난 주 vs 4주 baseline 비교
//   2. velocity 30%+ + 임계 건수 (code=3, design=2) → isEmerging
//   3. emerging 5+ (code) / 3+ (design) → GrowthDecision 자동 생성
model TechTrend {
  id          String   @id @default(cuid())
  weekStart   DateTime
  domain      String // "code" | "design"
  keyword     String
  occurrences Int
  velocityPct Float
  isEmerging  Boolean  @default(false)

  createdAt DateTime @default(now())

  @@unique([weekStart, keyword, domain])
  @@index([weekStart, isEmerging])
  @@index([domain, weekStart])
}

// ============================================================
// Cognitive Memory — Phase 6 Master Cognitive Loop
// ============================================================
//
// 매 15 분 마스터(또는 에이전트)가 (관찰, 추론, 결정, 결과) 사이클을 한 번
// 돌리고 그 트레이스를 여기에 기록한다. 다음 사이클의 reason_about_state
// 는 최근 lesson 들을 컨텍스트로 받아 과거 후회를 반복하지 않는다.
//
// 필드
//   actor        : "master" | "agent_<id>"
//   observed     : observe() 가 만든 메트릭 dict (json)
//   reasoning    : LLM chain-of-thought
//   decision     : 결정 JSON (decisions 배열 직렬화)
//   actionTaken  : "trigger_curious_crawl=executed; no_action=executed" 같은 요약
//   outcome      : reflect_on_recent 가 채우는 결과 텍스트
//   outcomeScore : -1.0 ~ +1.0 (음수=후회)
//   lesson       : 다음 사이클 LLM 프롬프트로 들어갈 1 줄 교훈
//
// 인덱스 두 개:
//   actor + timestamp(desc) — 최근 lesson 조회 / find_similar_past_decisions
//   actor + outcomeScore     — 정렬된 후회/성공 사례 검색
model CognitiveMemory {
  id String @id @default(cuid())

  actor String // "master" | "agent_<id>"

  timestamp   DateTime @default(now())
  observed    Json
  reasoning   String   @db.Text
  decision    String   @db.Text
  actionTaken String?

  outcome      String? @db.Text
  outcomeScore Float?
  lesson       String? @db.Text

  // pgvector 임베딩 — observation/reasoning 의미 검색 (find_similar_past_decisions)
  // bge-m3 / SHA fallback 출력에서 384 차원으로 fit. Unsupported 라 raw SQL 로만 접근.
  // HNSW 인덱스는 scripts/setup_pgvector.sh 또는 alembic 마이그레이션에서 별도 생성.
  observedEmbedding  Unsupported("vector(384)")?
  reasoningEmbedding Unsupported("vector(384)")?

  createdAt DateTime @default(now())

  @@index([actor, timestamp(sort: Desc)])
  @@index([actor, outcomeScore])
}

// CognitiveAudit — Cognitive 결정의 환각 검증 / 감사 로그.
// 매 사이클의 결정마다 1 건. master_loop.cognitive_cycle 이 직접 기록.
model CognitiveAudit {
  id String @id @default(cuid())

  memoryId String // CognitiveMemory.id (FK 미지정 — 사이클 차단 시 memory 가 없을 수 있음)

  cycleType String // "scheduled" | "free_will" | "interrupt"

  // 환각 검증
  hallucinationScore Float? // 0~1, 1 = 확실히 환각
  consistencyScore   Float? // 0~1, 1 = 완전 일치
  schemaValid        Boolean  @default(true)
  riskyKeywords      String[] // delete / drop / shutdown 등

  // 차단 / 승인
  blockedActions   String[] // 환각으로 차단된 액션 이름 목록
  requiresApproval Boolean  @default(false)

  auditedAt DateTime @default(now())

  @@index([auditedAt(sort: Desc)])
  @@index([cycleType])
}

// ============================================================
// Phase 8 — Social Agent Network
// 에이전트 평판/신뢰 점수. agentId 는 별도 Agent 테이블이 없어 String 으로만
// 보관 (Grid heartbeat / Round 등에서 참조). 추후 Agent 테이블이 생기면
// `agent` relation 을 붙일 것.
// ============================================================
model AgentReputation {
  id            String   @id @default(cuid())
  agentId       String   @unique
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  avgQuality    Float    @default(0.5)
  trustScore    Float    @default(0.5)
  disputesWon   Int      @default(0)
  disputesLost  Int      @default(0)
  lastUpdated   DateTime @default(now())

  @@index([trustScore(sort: Desc)])
  @@index([lastUpdated(sort: Desc)])
}

// ============================================================
// Phase 9.ι — Sleep Cycle / Memory Consolidation
// MemoryConsolidator 가 episodic CognitiveMemory 들을 묶어 추출한
// 일반화 규칙(semantic rule). 같은 topic 이 다시 추출되면 sourceCount 증가
// + confidence 평균 + lastReinforced 갱신 (강화). DreamGenerator 가
// 생성한 규칙은 fromDream=true 로 표시되며 confidence 가 낮음.
// 마이그레이션:
//   prisma migrate dev --name add_semantic_rule
//   (또는) prisma db push  --schema=modules/hwarang-web/prisma/schema.prisma
// ============================================================
model SemanticRule {
  id             String   @id @default(cuid())
  topic          String
  rule           String   @db.Text
  confidence     Float    @default(0.5)
  exceptions     Json     @default("[]")
  sourceCount    Int      @default(1)
  lastReinforced DateTime @default(now())
  fromDream      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([topic])
  @@index([lastReinforced(sort: Desc)])
  @@index([fromDream, confidence])
}

// ============================================================
// Phase 9.ζ — Meta-cognition + Theory of Mind
// 사용자별 멘탈 모델. 전문성/관심사/대화 스타일/믿음/오개념을 누적 추적.
// expertise:    {도메인: 0~1 숙련도}
// interests:    [string]
// communicationStyle: formal | casual | technical | neutral
// knownBeliefs:    [{topic, belief, confidence}]
// misconceptions:  [{topic, false_belief}]
// 마이그레이션 필요: `pnpm prisma migrate dev --name add_user_mental_model`
// ============================================================
model UserMentalModel {
  id                 String   @id @default(cuid())
  userId             String   @unique
  expertise          Json     @default("{}")
  interests          Json     @default("[]")
  communicationStyle String   @default("neutral")
  knownBeliefs       Json     @default("[]")
  misconceptions     Json     @default("[]")
  lastUpdated        DateTime @default(now())

  @@index([lastUpdated(sort: Desc)])
}

// ============================================================
// CLI 다중 기기 로그인 — Device Authorization Flow (RFC 8628 패턴)
//
// 흐름:
//   1) CLI → cli-init → nonce + login_url 발급 (10분 TTL)
//   2) 사용자가 다른 기기 브라우저로 login_url 접속 → /agent-login?nonce=...&cli=1
//   3) 브라우저에서 로그인 후 cli-approve → ApiKey 생성 + rawKey 저장
//   4) CLI 가 cli-poll 폴링 → status=approved 시 rawKey 1회 수령
//
// 보안:
//   - rawKey 는 cli-poll 응답에서 단 1회만 노출 (응답 직후 null 처리)
//   - nonce 만료 시 status=expired 로 lazy cleanup
//   - cli-init / cli-poll 은 nonce 가 인증 매개체 (세션 불필요)
//   - cli-approve 는 NextAuth 세션 필수
//
// 마이그레이션: `pnpm prisma migrate dev --name add_cli_login_request`
// ============================================================
model CliLoginRequest {
  id    String @id @default(cuid())
  nonce String @unique // base64url 32 bytes

  // CLI 가 cli-init 시 보내는 device 메타
  deviceName        String?
  deviceOs          String?
  deviceArch        String?
  deviceGpu         String?
  deviceHostname    String?
  deviceFingerprint String?

  status            String  @default("pending") // pending / approved / denied / expired
  apiKeyId          String? // 승인 후 발급된 ApiKey.id
  rawKey            String? // cli-poll 응답으로 단 1회 전달, 전달 후 null
  approvedByUserId  String?

  createdAt DateTime @default(now())
  expiresAt DateTime // createdAt + 10분

  @@index([nonce])
  @@index([expiresAt])
  @@index([status])
}

// ============================================================
// 다중 인스턴스 cron job 분산 락 (HSEE Phase 1-4)
//
// 목적:
//   HWARANG_SCHEDULER_LEADER 환경변수 가드의 백업 안전망.
//   leader 가 2대 동시에 켜진 사고에서도 같은 잡이 동시에 실행되지 않도록
//   PostgreSQL UPSERT 멱등성으로 보장.
//
// 동작:
//   - 잡 시작 직전 INSERT ... ON CONFLICT (job_name)
//     DO UPDATE WHERE expires_at < NOW() RETURNING host
//   - RETURNING 이 본인 host = 획득, 빈 결과 = 다른 인스턴스 보유 → skip
//   - 잡 종료 시 DELETE WHERE host = me → 즉시 해제
//   - TTL 만료 시 자동 takeover (인스턴스 강제 종료 / 크래시 대비)
//
// 마이그레이션: `pnpm prisma migrate dev --name add_scheduler_lock`
// ============================================================
model SchedulerLock {
  jobName    String   @id @map("job_name")
  host       String
  acquiredAt DateTime @default(now()) @map("acquired_at")
  expiresAt  DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("scheduler_lock")
}
