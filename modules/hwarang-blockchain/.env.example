# ============================================================
# 화랑 AI - hwarang-blockchain 환경변수 (Hardhat / Polygon)
# ============================================================
# 사용법: cp .env.example .env 후 값 채우기
# 마지막 업데이트: 2026-04-28
# ============================================================

# ────────────────────────────────────────
# RPC 엔드포인트 (hardhat.config.ts, api/blockchain-client.ts)
# ────────────────────────────────────────
# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-rpc.com
# Polygon Mumbai 테스트넷
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# ────────────────────────────────────────
# 배포 / 트랜잭션 서명 (CRITICAL — 운영 시 KMS 사용)
# ────────────────────────────────────────
# TODO: 운영 환경에서는 절대 평문 저장 금지. AWS KMS / HashiCorp Vault 권장.
# Hardhat 배포용 개인키 (테스트넷 한정)
DEPLOYER_PRIVATE_KEY=
# 런타임 트랜잭션 서명 (api/blockchain-client.ts)
BLOCKCHAIN_PRIVATE_KEY=

# ────────────────────────────────────────
# 컨트랙트 주소 (배포 후 채우기)
# ────────────────────────────────────────
HWR_TOKEN_ADDRESS=
HWR_EMISSION_ADDRESS=
