{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "Hwarang Grid Agent",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true,
        "execute": true,
        "sidecar": true,
        "scope": [
          {
            "name": "binaries/hwarang-agent",
            "sidecar": true,
            "args": true
          }
        ]
      },
      "notification": {
        "all": true
      },
      "dialog": {
        "all": false,
        "message": true,
        "ask": true
      },
      "process": {
        "all": false,
        "relaunch": true,
        "exit": false
      }
    },
    "bundle": {
      "active": true,
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "ai.hwarang.grid",
      "targets": "all",
      "category": "Utility",
      "shortDescription": "화랑 AI Grid 에이전트",
      "longDescription": "GPU 공유 네트워크에 참여하여 AI 학습에 기여하고 HWR 코인을 받으세요.",
      "copyright": "2025 Persismore",
      "externalBin": [
        "binaries/hwarang-agent"
      ],
      "macOS": {
        "minimumSystemVersion": "11.0",
        "exceptionDomain": "hwarang.ai"
      },
      "deb": {
        "scripts": {
          "postinst": "../installer/linux/postinst",
          "prerm": "../installer/linux/prerm"
        }
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "nsis": {
          "installerHooks": "../installer/windows/postinstall.nsh"
        }
      }
    },
    "systemTray": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true
    },
    "windows": [
      {
        "label": "settings",
        "title": "화랑 Grid 설정",
        "url": "settings.html",
        "width": 600,
        "height": 720,
        "minWidth": 520,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true,
        "fileDropEnabled": false
      }
    ],
    "updater": {
      "active": true,
      "endpoints": [
        "https://hwarang.ai/api/agent/update/latest.json"
      ],
      "dialog": true,
      "pubkey": ""
    },
    "security": {
      "csp": null,
      "dangerousRemoteDomainIpcAccess": []
    }
  },
  "plugins": {
    "deep-link": {
      "schemes": ["hwarang-grid"]
    }
  }
}
