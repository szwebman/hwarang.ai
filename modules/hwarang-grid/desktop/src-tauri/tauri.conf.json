{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "Hwarang Grid Agent",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true,
        "execute": true,
        "sidecar": true,
        "scope": [
          {
            "name": "hwarang-agent",
            "cmd": "hwarang-agent",
            "args": true
          },
          {
            "name": "python3",
            "cmd": "python3",
            "args": true
          },
          {
            "name": "nvidia-smi",
            "cmd": "nvidia-smi",
            "args": true
          }
        ]
      },
      "notification": {
        "all": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "scope": ["$HOME/.hwarang/**"]
      }
    },
    "bundle": {
      "active": true,
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "ai.hwarang.grid",
      "targets": "all",
      "category": "Utility",
      "shortDescription": "화랑 AI Grid 에이전트",
      "longDescription": "GPU 공유 네트워크에 참여하여 AI 학습에 기여하고 HWR 코인을 받으세요.",
      "copyright": "© 2025 Persismore. All rights reserved.",
      "macOS": {
        "minimumSystemVersion": "11.0",
        "dmg": {
          "appPosition": { "x": 180, "y": 170 },
          "applicationFolderPosition": { "x": 480, "y": 170 },
          "windowSize": { "width": 660, "height": 400 }
        }
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "nsis": {
          "installMode": "currentUser",
          "languages": ["Korean", "English"],
          "displayLanguageSelector": false
        }
      },
      "linux": {
        "appimage": {
          "bundleMediaFramework": false
        }
      }
    },
    "systemTray": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true,
      "title": "화랑 Grid"
    },
    "windows": [],
    "security": {
      "csp": null
    },
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://api.hwarang.ai/agent/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": ""
    }
  }
}
