# ============================================================
# 화랑 AI - hwarang-grid 환경변수 (Grid 마스터 + 에이전트)
# ============================================================
# 사용법: cp .env.example .env 후 값 채우기
# 마지막 업데이트: 2026-04-28
# ============================================================

# ────────────────────────────────────────
# Grid Master (coordinator/routes.py)
# ────────────────────────────────────────
# 마스터 admin API 보호. 비워두면 admin 엔드포인트 접근 불가.
HWARANG_ADMIN_KEY=

# ────────────────────────────────────────
# Grid Agent — 마스터 연결 (config/agent_config.py)
# ────────────────────────────────────────
# 마스터 서버 URL (기본 https://hwarang.ai 또는 로컬)
HWARANG_MASTER_URL=http://localhost:8000
# 에이전트 식별자 (자동 생성 가능)
HWARANG_AGENT_ID=
# 에이전트 인증 키 (마스터 등록 시 발급)
HWARANG_AGENT_KEY=
# 호환 별칭 (modules/_http_util.py)
HWARANG_API_KEY=
# 에이전트 지역 코드 (kr, us, jp 등)
HWARANG_REGION=kr
HWARANG_AGENT_REGION=kr

# ────────────────────────────────────────
# 에이전트 동작 모드 (agent_main.py)
# ────────────────────────────────────────
# Cognitive 에이전트 모드 (자율 의사결정)
HWARANG_AGENT_COGNITIVE=false
# LLM 기반 결정 사용 여부
HWARANG_AGENT_LLM_DECIDE=false
# 자율 결정 LLM URL (cognitive/decision_engine.py)
HWARANG_AGENT_DECISION_LLM_URL=

# WebSocket vs Polling
HWARANG_PREFER_WEBSOCKET=true
HWARANG_POLL_INTERVAL=60
HWARANG_STATUS_INTERVAL=30

# ────────────────────────────────────────
# 콜백 서버 (cognitive/callback_server.py)
# ────────────────────────────────────────
HWARANG_AGENT_CALLBACK_PORT=7878
HWARANG_AGENT_CALLBACK_TOKEN=
# 외부 도달 가능한 공개 URL (NAT/방화벽 환경)
HWARANG_AGENT_CALLBACK_PUBLIC_URL=

# ────────────────────────────────────────
# 데이터 크롤러 (modules/data_crawler.py)
# ────────────────────────────────────────
# law.go.kr 공공 데이터 API (선택)
LAW_GO_KR_API_KEY=
# GitHub 인증 토큰 (rate limit 상향: 60→5000 req/h)
GITHUB_TOKEN=

# ────────────────────────────────────────
# 로깅
# ────────────────────────────────────────
HWARANG_LOG_LEVEL=INFO
