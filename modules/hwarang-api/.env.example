# ============================================================
# 화랑 AI - hwarang-api 환경변수 (FastAPI / 학습 / Cognitive)
# ============================================================
# 사용법: cp .env.example .env 후 값 채우기.
# 비어 있어도 동작은 하지만 해당 기능은 비활성화됩니다.
# 마지막 업데이트: 2026-04-28
# ============================================================

# ============================================================
# 필수 (Required) - 미설정 시 시작 실패
# ============================================================
DATABASE_URL=postgresql://hwarang:password@localhost:5432/hwarang
REDIS_URL=redis://localhost:6379

# 화랑 API 자체 호스트 / CORS
HWARANG_API_HOST=0.0.0.0
HWARANG_API_PORT=8000
HWARANG_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Next.js → hwarang-api 내부 호출 인증. 비워두면 로컬 개발은 무인증 허용.
# routers/learning.py, routers/cognitive.py 가 사용.
HWARANG_INTERNAL_KEY=

# Phase 8.ε — Self-Modify / Sleep 라우터 admin 인증.
# routers/self_modify.py, routers/sleep.py 가 사용.
HWARANG_ADMIN_TOKEN=

# 로깅 레벨 (DEBUG | INFO | WARNING | ERROR)
HWARANG_LOG_LEVEL=INFO

# ============================================================
# LLM 서빙 (knowledge/llm.py)
# ============================================================
# vLLM OpenAI 호환 엔드포인트 (텍스트 LLM 메인)
HWARANG_LLM_URL=http://localhost:8000/v1
HWARANG_LLM_API_KEY=
HWARANG_LLM_MODEL=qwen2.5-72b
HWARANG_LLM_TIMEOUT=30.0

# 모델 라우팅
HWARANG_DEFAULT_MODEL=
HWARANG_ROUTER_FALLBACK=qwen2.5

# ============================================================
# Vision-to-Code (VLM) — Qwen2.5-VL
# ============================================================
# scripts/start_vlm.sh 로 별도 vLLM 인스턴스 띄움.
# --served-model-name 과 HWARANG_VLM_MODEL 일치 필수.
HWARANG_VLM_URL=http://localhost:8002
HWARANG_VLM_MODEL=hwarang-vl

# ============================================================
# Grid / HFL (Federated Learning) — grid/sharder.py, routers/grid.py
# ============================================================
HWARANG_SHARD_DIR=/var/hwarang/shards
HWARANG_SHARD_BASE_URL=http://localhost:8000/static/shards
HWARANG_SHARD_S3_BUCKET=
HWARANG_SHARD_MAX_LINES=10000
HWARANG_LORA_DIR=/var/hwarang/lora
HWARANG_MASTER_URL=http://localhost:8000
# HFL 마스터 저장소 루트 (routers/grid.py)
HFL_STORAGE=/mnt/nvme2/hwarang/hfl

# ============================================================
# 임베딩 (knowledge/embeddings.py — bge-m3 등)
# ============================================================
EMBEDDING_SERVER_URL=
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT=10
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# ============================================================
# HLKM (Hwarang Living Knowledge Mesh)
# ============================================================
HLKM_MASTER_KEY=
HALFLIFE_MODEL_DIR=/var/hwarang/halflife
HLKM_GAP_PROPOSAL_DIR=/var/hwarang/hlkm/gaps
HLKM_FORGET_REPORT_DIR=/var/hwarang/hlkm/forget
HLKM_SNAPSHOT_DIR=/var/hlkm/snapshots
HLKM_MODEL_DIR=/var/hlkm

# Federated Fact-Check (federated_fact_check.py)
HLKM_INSTANCE_ID=local-hlkm
HLKM_INSTANCE_NAME=HWARANG-HLKM
HLKM_VERSION=0.1.0
HLKM_FEDERATION_KEY=/var/hlkm/federation_private_key.pem
# 인스턴스 서명용 ed25519 개인키 (PEM). 비워두면 federation 응답 서명 비활성.
HLKM_FEDERATION_PRIVATE_KEY=

# Sybil 방어 IP salt (sybil_defense.py) — 변경 시 IP 해시 무효화.
HWARANG_SYBIL_IP_SALT=hwarang-sybil-v1

# ============================================================
# KYC / Proof of Personhood (knowledge/proof_of_personhood.py)
# ============================================================
# PASS 인증
HWARANG_POP_PASS_API_KEY=
HWARANG_POP_PASS_CLIENT_ID=
HWARANG_POP_PASS_ENDPOINT=
# WorldID
HWARANG_POP_WORLDID_APP_ID=
HWARANG_POP_WORLDID_API_KEY=
HWARANG_POP_WORLDID_ACTION=hwarang-pop
# BrightID
HWARANG_POP_BRIGHTID_CONTEXT=hwarang
HWARANG_POP_BRIGHTID_NODE=https://app.brightid.org/node/v6
# Proof of Humanity
HWARANG_POP_POH_RPC_URL=
HWARANG_POP_POH_CONTRACT_ADDR=
# 고유성 해시 salt (proof_of_personhood.py) — 변경 시 사용자 매핑 변경됨.
HWARANG_POP_UNIQ_SALT=hwarang-pop-v1

# ============================================================
# 알림 (knowledge/notifier.py) — Slack / Discord / SMTP
# ============================================================
# Slack 인커밍 webhook URL.
HWARANG_SLACK_WEBHOOK_URL=
# Discord webhook URL.
HWARANG_DISCORD_WEBHOOK_URL=
# SMTP (관리자 메일)
HWARANG_SMTP_HOST=
HWARANG_SMTP_PORT=587
HWARANG_SMTP_USER=
HWARANG_SMTP_PASSWORD=
HWARANG_SMTP_FROM=
HWARANG_ADMIN_EMAILS=

# ============================================================
# HWR 코인 (knowledge/coin.py — 블록체인)
# ============================================================
HWR_RPC_URL=
HWR_CONTRACT_ADDR=
# TODO: 운영 시 KMS / Vault 등에서 주입. 평문 저장 금지.
HWR_MINTER_PRIVATE_KEY=
HWR_CHAIN_ID=1
HWR_ANCHOR_CONTRACT_ADDR=
HWR_DECIMALS=18
HWR_WALLET_MAP_PATH=

# ============================================================
# 외부 데이터 / 1차 출처 API (knowledge/primary_source_apis.py)
# ============================================================
# 자기 질문에서 confidence 가 낮을 때 즉시 호출되는 한국 공공 데이터 API.
# 키가 비어 있으면 해당 어댑터는 자동 비활성.
LAW_GO_KR_API_KEY=
WEATHER_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
HWARANG_LAW_API_KEY=
HWARANG_KOSIS_API_KEY=
HWARANG_NTS_API_KEY=
HWARANG_MFDS_API_KEY=
HWARANG_ECOS_API_KEY=
HWARANG_KMA_API_KEY=
KMA_API_KEY=
NEWS_API_KEY=
HRAG_HTTP_TIMEOUT=10.0

# 실시간 웹 검색 (knowledge/realtime_search.py) — Naver Search API
# 발급: https://developers.naver.com/apps/#/register (무료 25,000 queries/day)
# NAVER_CLIENT_ID/_SECRET 가 비어 있으면 자동으로 HWARANG_NAVER_* 값 사용.
HWARANG_NAVER_CLIENT_ID=
HWARANG_NAVER_CLIENT_SECRET=

# 내부 메타 검색 (knowledge/web.py — 옵션)
WEB_SEARCH_URL=
WEB_SEARCH_API_KEY=
WEB_HTTP_TIMEOUT=10.0

# ============================================================
# Code Engine — GitHub 수집 (research/dev_source_crawler.py)
# ============================================================
# 비워두면 unauthenticated 60 req/h, 토큰 있으면 5000 req/h.
# 발급: https://github.com/settings/tokens (public_repo 권한만 필요)
HWARANG_GITHUB_TOKEN=

# ============================================================
# 도구 / 샌드박스 (research/quality/code_executor.py)
# ============================================================
# Python 외부 샌드박스 (선택, 미사용 시 로컬 docker/firejail/subprocess)
PYTHON_SANDBOX_URL=
HWARANG_SANDBOX_PREFER=docker         # docker | firejail | subprocess
HWARANG_SANDBOX_MEMORY=512m
HWARANG_SANDBOX_CPUS=0.5
HWARANG_SANDBOX_TIMEOUT=10

# ============================================================
# LoRA 평가 워커 (HFL 라운드 후) — workers/lora_evaluator_worker.py
# ============================================================
HWARANG_EVAL_SET_DIR=/var/hwarang/eval_sets
HWARANG_EVAL_VLLM_URL=http://localhost:8001
HWARANG_EVAL_MAX_SAMPLES=100
HWARANG_EVAL_TIMEOUT_SEC=60
HWARANG_EVAL_BATCH=10
HWARANG_EVAL_WORKER_POLL_SEC=30
HWARANG_EVAL_WORKER_GRACE_MIN=2
HWARANG_EVAL_WORKER_BACKOFF_SEC=60

# 외부 LoRA evaluator / rollback URL (옵션) — code_round_quality.py
HWARANG_LORA_EVALUATOR_URL=
HWARANG_LORA_ROLLBACK_URL=
HWARANG_CODE_EVAL_SET=/var/hwarang/benchmarks/code_eval.jsonl

# ============================================================
# Cognitive Layer (Phase 6 — Master Cognitive Loop)
# ============================================================
HWARANG_COGNITIVE_ENABLED=true
HWARANG_COGNITIVE_MAX_ACTIONS_DAY=20
HWARANG_COGNITIVE_INTERVAL_MIN=15
# 라운드 의향 조사 (cognitive/orchestrator.py)
HWARANG_COGNITIVE_MIN_WILLING=3
HWARANG_COGNITIVE_MAX_CONSULT=20
HWARANG_COGNITIVE_CONSULT_TIMEOUT=5.0
# 가드레일 (cognitive/guardrails_advanced.py)
HWARANG_COGNITIVE_MAX_SAME_ACTION=5
HWARANG_COGNITIVE_MAX_LLM_TOKENS_DAY=1000000
HWARANG_COGNITIVE_MAX_FAILED_CYCLES=5

# ============================================================
# Hallucination Check (cognitive/hallucination_check.py)
# ============================================================
HWARANG_HALLUC_CHECK_ENABLED=true
HWARANG_HALLUC_REPEATS=3
HWARANG_HALLUC_CONSISTENCY_THRESHOLD=0.6

# ============================================================
# Free Will Mode (Phase 7 — 자유의사)
# ============================================================
# cron 없이 적응적 간격으로 연속 사고. 기본 OFF — 검증 후 활성.
HWARANG_FREEWILL_ENABLED=false
HWARANG_FREEWILL_MIN_SEC=60
HWARANG_FREEWILL_MAX_SEC=1800

# ============================================================
# Phase 8 — Self-Modify / Auto-Critique
# ============================================================
# Phase 8.γ Constitutional auto-replace — 응답 후 자기 비평 → 자동 교체.
# Next.js / hwarang-web 측에서도 동일 변수 참조.
HWARANG_AUTO_CRITIQUE=false
# Phase 8.ε Self-Modify Draft PR 자동 생성 (gh CLI 필요)
# '1' 일 때만 PR 생성 허용. cognitive/self_modify/pr_creator.py 가 검사.
HWARANG_SELF_MODIFY_ENABLED=0
# 대상 GitHub repo (예: gallera/sames). 비워두면 origin 사용.
HWARANG_SELF_MODIFY_REPO=

# ============================================================
# Online RLHF (즉시 1 step gradient + LoRA hot-swap)
# ============================================================
# 매 RLHF 피드백마다 즉시 학습. 별도 GPU 권장.
HWARANG_ONLINE_LORA_ENABLED=false
HWARANG_ONLINE_LORA_DIR=/var/hwarang/online_lora
HWARANG_ONLINE_SAVE_STEPS=10
HWARANG_ONLINE_EVAL_FREQ=5
HWARANG_ONLINE_ROLLBACK_DROP=0.05
# LoRA 학습 시 베이스 모델 경로 (actual_trainer 가 사용).
HWARANG_BASE_MODEL_PATH=/mnt/nvme2/hwarang/models/hwarang-v5-awq
# vLLM hot-reload 호출 대상 (vLLM 0.7+ /v1/load_lora_adapter)
HWARANG_VLLM_URL=http://localhost:8001

# ============================================================
# HSEE 자동 학습 (learning/auto_trainer.py, auto_trigger.py)
# ============================================================
HSEE_TRAINING_THRESHOLD=1000
HSEE_LORA_BASE_DIR=/mnt/nvme2/hwarang/lora_adapters
HSEE_EWC_LAMBDA=1000.0
HSEE_REPLAY_RATIO=0.3
HSEE_MIN_SAMPLES_PER_ROUND=1000
HSEE_MIN_NEGATIVE_RATIO=0.10
HSEE_TRIGGER_COOLDOWN_HOURS=6
HSEE_FISHER_SNAPSHOT_DIR=/var/hwarang/fisher_snapshots
HSEE_LORA_OUTPUT_DIR=/mnt/nvme2/hwarang/lora_adapters
HSEE_BENCHMARK_DIR=/var/hwarang/benchmarks

# ============================================================
# Adversarial / Federated Inference (선택)
# ============================================================
# Next.js 내부 호출 (learning/adversarial_tester.py, federated_inference.py)
HWARANG_INTERNAL_URL=http://localhost:3000
