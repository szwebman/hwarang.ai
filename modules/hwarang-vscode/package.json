{
  "name": "hwarang-vscode",
  "displayName": "화랑 AI",
  "description": "AI 코딩 어시스턴트 - 채팅, 파일 편집, 터미널 실행, 코드 검색",
  "version": "0.3.0",
  "publisher": "hwarang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "assistant",
    "code generation",
    "chat",
    "hwarang",
    "화랑",
    "코딩",
    "coding assistant"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "hwarang.login",
        "title": "화랑 AI: 로그인",
        "icon": "$(sign-in)"
      },
      {
        "command": "hwarang.logout",
        "title": "화랑 AI: 로그아웃",
        "icon": "$(sign-out)"
      },
      {
        "command": "hwarang.showTokenStatus",
        "title": "화랑 AI: 토큰 현황",
        "icon": "$(pulse)"
      },
      {
        "command": "hwarang.openDashboard",
        "title": "화랑 AI: 대시보드 열기",
        "icon": "$(dashboard)"
      },
      {
        "command": "hwarang.openChat",
        "title": "화랑 AI: 채팅 열기",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "hwarang.newChat",
        "title": "화랑 AI: 새 대화",
        "icon": "$(add)"
      },
      {
        "command": "hwarang.explainSelection",
        "title": "화랑 AI: 코드 설명"
      },
      {
        "command": "hwarang.fixSelection",
        "title": "화랑 AI: 버그 수정"
      },
      {
        "command": "hwarang.refactorSelection",
        "title": "화랑 AI: 리팩토링"
      },
      {
        "command": "hwarang.generateTests",
        "title": "화랑 AI: 테스트 생성"
      },
      {
        "command": "hwarang.inlineChat",
        "title": "화랑 AI: 인라인 채팅"
      },
      {
        "command": "hwarang.switchMode",
        "title": "화랑 AI: 모드 전환 (자동/수동/플랜)",
        "icon": "$(settings-gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hwarang-sidebar",
          "title": "화랑 AI",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "hwarang-sidebar": [
        {
          "type": "webview",
          "id": "hwarang.chatView",
          "name": "채팅"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "submenu": "hwarang.editorContext",
          "group": "hwarang"
        }
      ],
      "hwarang.editorContext": [
        {
          "command": "hwarang.explainSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "hwarang.fixSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "hwarang.refactorSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "hwarang.generateTests",
          "when": "editorHasSelection"
        }
      ]
    },
    "submenus": [
      {
        "id": "hwarang.editorContext",
        "label": "화랑 AI"
      }
    ],
    "keybindings": [
      {
        "command": "hwarang.openChat",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      },
      {
        "command": "hwarang.inlineChat",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "hwarang.newChat",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "hwarang.chatView.visible"
      },
      {
        "command": "hwarang.switchMode",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "화랑 AI",
      "properties": {
        "hwarang.provider": {
          "type": "string",
          "default": "hwarang",
          "enum": ["hwarang", "openai", "anthropic"],
          "enumDescriptions": [
            "화랑 AI (기본, hwarang.ai)",
            "OpenAI (API 키 필요)",
            "Anthropic Claude (API 키 필요)"
          ],
          "description": "LLM 공급자 선택"
        },
        "hwarang.apiUrl": {
          "type": "string",
          "default": "https://hwarang.ai",
          "description": "화랑 AI API 서버 주소"
        },
        "hwarang.model": {
          "type": "string",
          "default": "hwarang-default",
          "description": "사용할 모델"
        },
        "hwarang.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API 키 (OpenAI 공급자 사용 시)"
        },
        "hwarang.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API 키 (Anthropic 공급자 사용 시)"
        },
        "hwarang.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "샘플링 온도 (0: 정확, 2: 창의적)"
        },
        "hwarang.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "응답 최대 토큰 수"
        },
        "hwarang.autoApplyEdits": {
          "type": "boolean",
          "default": false,
          "description": "[레거시] 파일 수정 시 확인 없이 자동 적용 (hwarang.mode로 대체됨)"
        },
        "hwarang.mode": {
          "type": "string",
          "default": "manual",
          "enum": ["auto", "manual", "plan"],
          "enumDescriptions": [
            "자동 모드: 파일 생성/수정/삭제, 명령 실행을 확인 없이 자동 적용",
            "수동 모드: 모든 파일 변경과 명령 실행 전 승인 받음 (안전, 기본값)",
            "플랜 모드: 실제 파일 변경 없이 계획만 출력 (읽기 전용)"
          ],
          "description": "화랑 AI 실행 모드"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch --sourcemap",
    "lint": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0",
    "@vscode/vsce": "^2.27.0"
  },
  "dependencies": {}
}
