# Database
DATABASE_URL=postgresql+asyncpg://hwarang:password@localhost:5432/hwarang
REDIS_URL=redis://localhost:6379

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production

# Model
MODEL_PATH=./checkpoints/hwarang-small
DEFAULT_MODEL=hwarang-small

# Web UI
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
HWARANG_API_URL=http://localhost:8000

# External API Keys (optional, for CLI multi-provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================================
# Storage Paths (멀티 디스크 환경변수 - configs/storage.yaml 대신 사용 가능)
# ============================================================
# 디스크 1: 학습 (빠른 NVMe)
# HWARANG_TRAIN_DATA_DIR=/mnt/nvme0/hwarang/train_data
# HWARANG_CHECKPOINT_DIR=/mnt/nvme0/hwarang/checkpoints
# HWARANG_TOKENIZER_DIR=/mnt/nvme0/hwarang/tokenizer

# 디스크 2: Raw 데이터 (대용량)
# HWARANG_DOWNLOAD_DIR=/mnt/nvme1/hwarang/downloads
# HWARANG_GITHUB_DIR=/mnt/nvme1/hwarang/raw/github
# HWARANG_BLOG_DIR=/mnt/nvme1/hwarang/raw/blogs
# HWARANG_AIHUB_DIR=/mnt/nvme1/hwarang/raw/aihub
# HWARANG_PROCESSED_DIR=/mnt/nvme1/hwarang/processed
# HWARANG_SFT_DIR=/mnt/nvme1/hwarang/sft
# HWARANG_DPO_DIR=/mnt/nvme1/hwarang/dpo

# 디스크 3: 서빙 + 백업 (안정성)
# HWARANG_MODEL_DIR=/mnt/nvme2/hwarang/models
# HWARANG_LORA_DIR=/mnt/nvme2/hwarang/lora_adapters
# HWARANG_VECTORDB_DIR=/mnt/nvme2/hwarang/vectordb
# HWARANG_BACKUP_DIR=/mnt/nvme2/hwarang/backup
